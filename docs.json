{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Komprai",
  "colors": {
    "primary": "#ce6f04",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Console",
          "icon": "display",
          "href": "https://console.komprai.dev"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/komprai"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guias",
        "groups": [
          {
            "group": "Início",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Referência",
            "pages": [
              "api-reference/introduction"
            ]
          }
        ]
      },
      {
        "tab": "Core API",
        "openapi": "api-reference/core.json"
      },
      {
        "tab": "Catalog API",
        "openapi": "api-reference/catalog.json"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://www.komprai.com/"
  },
  "navbar": {
    "links": [
      {
        "label": "Suporte",
        "href": "mailto:support@komprai.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://console.komprai.dev"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/komprai"
    }
  }
}
