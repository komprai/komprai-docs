{
  "openapi": "3.0.3",
  "info": {
    "title": "Komprai Catalog API",
    "description": "Documentação automática das rotas da API de Catálogo",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "better-auth.session_token"
      }
    },
    "schemas": {}
  },
  "paths": {
    "/catalog/health": {
      "get": {
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/api/catalog/offers": {
      "get": {
        "summary": "List offers",
        "tags": [
          "Catalog"
        ],
        "description": "Returns all offers available in the current region. The region is determined by which Catalog API instance receives the request.",
        "responses": {
          "200": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "id",
                      "title",
                      "price",
                      "currency",
                      "region"
                    ],
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "price": {
                        "type": "number"
                      },
                      "currency": {
                        "type": "string"
                      },
                      "region": {
                        "type": "string"
                      },
                      "imageUrl": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create offer",
        "tags": [
          "Catalog"
        ],
        "description": "Publishes a new offer to the catalog in the current region.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title",
                  "price"
                ],
                "properties": {
                  "title": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "price": {
                    "minimum": 0,
                    "type": "number"
                  },
                  "currency": {
                    "type": "string"
                  },
                  "imageUrl": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Default Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "title",
                    "price"
                  ],
                  "properties": {
                    "title": {
                      "minLength": 1,
                      "type": "string"
                    },
                    "price": {
                      "minimum": 0,
                      "type": "number"
                    },
                    "currency": {
                      "type": "string"
                    },
                    "imageUrl": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "cookieAuth": []
    }
  ]
}